{
  // ╔═══════════════════════════════════════════════════════════════════════════╗
  // ║  VS Code Settings — Chunjie Liu                                           ║
  // ║  Organized by: Editor → Workbench → Files → Terminal → VCS →              ║
  // ║                Languages → AI → Database → Remote → Tools                 ║
  // ╚═══════════════════════════════════════════════════════════════════════════╝

  // ═══════════════════════════════════════════════════════════════════════════
  // 🎨  1. EDITOR — APPEARANCE
  // ═══════════════════════════════════════════════════════════════════════════

  // 📝 Font & Typography
  "editor.fontSize": 14, // Base font size for editor text
  "editor.fontFamily": "'Cascadia Code', 'Fira Code', 'Courier New', monospace, Operator Mono, Menlo, Monaco",
  "editor.fontLigatures": true, // Enable programming ligatures (==, ->, >=, etc.)

  // 📄 Text Layout & Wrapping - How text is displayed and wrapped
  "editor.wordWrap": "on", // Wrap long lines automatically
  "editor.wrappingIndent": "same", // Maintain indentation on wrapped lines
  "editor.wordWrapColumn": 80, // Wrap at 80 characters (standard coding width)
  "editor.renderWhitespace": "all", // Show all whitespace characters for debugging
  "editor.renderControlCharacters": true, // Display control characters (tabs, spaces, etc.)

  // 🔍 Code Structure & Navigation - Visual aids for code organization
  "editor.showFoldingControls": "always", // Always show fold/unfold controls
  "editor.foldingStrategy": "indentation", // Use indentation to determine foldable regions
  "editor.linkedEditing": true, // Edit matching HTML/XML tags simultaneously
  "editor.bracketPairColorization.enabled": true, // Color-code matching brackets
  "editor.guides.bracketPairs": true, // Show lines connecting bracket pairs
  "editor.occurrencesHighlight": "multiFile", // Highlight same symbols across multiple files

  // 🎯 Cursor & Animation - Cursor behavior and visual effects
  "editor.cursorBlinking": "expand", // Cursor expands when blinking
  "editor.cursorSmoothCaretAnimation": "on", // Smooth cursor movement animation
  "editor.accessibilitySupport": "off", // Disable accessibility features for performance

  // 🗺️ Minimap - Code overview panel on the right side
  "editor.minimap.enabled": true, // Show minimap for code navigation
  "editor.minimap.size": "fill", // Fill available space with minimap
  "editor.minimap.showSlider": "always", // Always show viewport slider
  "editor.minimap.renderCharacters": true, // Render actual characters in minimap
  "editor.minimap.maxColumn": 80, // Limit minimap width to 80 columns

  // ═══════════════════════════════════════════════════════════════════════════
  // ⚙️  2. EDITOR — BEHAVIOR & FORMATTING
  // ═══════════════════════════════════════════════════════════════════════════

  // 📐 Indentation & Code Formatting - How code is structured and formatted
  "editor.tabSize": 2, // Use 2 spaces for indentation (web dev standard)
  "editor.insertSpaces": true, // Auto-format files when saving
  "editor.formatOnPaste": true, // Auto-format when pasting code

  // 🧠 IntelliSense & Auto-completion - Smart code suggestions and completions
  "editor.acceptSuggestionOnEnter": "smart", // Accept suggestions on Enter only when appropriate
  "editor.acceptSuggestionOnCommitCharacter": false, // Don't auto-accept on punctuation
  "editor.suggest.preview": true, // Show suggestion previews
  "editor.suggestSelection": "first", // Auto-select first suggestion
  "editor.inlineSuggest.enabled": true, // Enable inline AI suggestions (Copilot)
  "editor.quickSuggestions": {
    // Control when to show suggestions
    "other": true, // Show for general code
    "comments": false, // Don't show in comments
    "strings": false // Don't show in string literals
  },
  "editor.quickSuggestionsDelay": 10, // Delay before showing suggestions (ms)
  "editor.suggestOnTriggerCharacters": true, // Show suggestions on trigger characters (., @, etc.)
  "editor.tabCompletion": "off", // Disable tab completion to avoid conflicts
  "editor.suggest.localityBonus": true, // Prefer suggestions from nearby code
  "editor.aiStats.enabled": true, // Enable AI statistics tracking
  "editor.formatOnSave": true, // Format on save (applies globally)

  // ═══════════════════════════════════════════════════════════════════════════
  // 🖥️  3. WORKBENCH & USER INTERFACE
  // ═══════════════════════════════════════════════════════════════════════════

  // 🎨 Theme & Visual Appearance - Overall VS Code look and feel
  "workbench.colorTheme": "Light Modern", // Light theme for better readability
  "workbench.iconTheme": "vscode-icons", // Material Design icons for files
  "material-icon-theme.folders.color": "#fdd835", // Yellow folder icons for visibility
  "workbench.activityBar.location": "top", // Move activity bar to top for more space
  "workbench.panel.showLabels": false, // Hide panel labels for cleaner look

  // 📂 Editor Tabs & Layout - How files are displayed in tabs
  "workbench.startupEditor": "agentSessionsWelcomePage", // Start with new file instead of welcome screen
  "workbench.editor.tabCloseButton": "left", // Put close button on left side of tabs
  "workbench.editor.tabActionLocation": "left", // Put tab actions on left side
  "workbench.editor.empty.hint": "hidden", // Hide hints in empty editor
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.ipynb": "jupyter-notebook",
    "file:/**/*.tsv": "jupyter-data-wrangler",
    "*.md": "default",
    "*.markdown": "default"
  },

  // 🗂️ File Explorer & Navigation - Sidebar file browser settings
  "workbench.tree.indent": 15, // Indentation for nested folders
  "workbench.tree.renderIndentGuides": "always", // Always show indentation guides in tree
  "workbench.list.openMode": "doubleClick", // Require double-click to open files
  "breadcrumbs.enabled": true, // Show breadcrumb navigation at top
  "workbench.browser.openLocalhostLinks": true, // Open localhost links in built-in browser
  "simpleBrowser.useIntegratedBrowser": true, // Use VS Code integrated browser
  "livePreview.customExternalBrowser": "Chrome", // External browser for live preview

  // 🔍 Explorer Behavior - File explorer interaction settings
  "explorer.confirmDragAndDrop": false, // Don't confirm when dragging files
  "explorer.confirmDelete": false, // Don't confirm when deleting files
  "explorer.autoReveal": false, // Don't auto-reveal files in explorer

  // ═══════════════════════════════════════════════════════════════════════════
  // 🖼️  4. WINDOW & SYSTEM
  // ═══════════════════════════════════════════════════════════════════════════

  // 🧰 Window Behavior
  "window.restoreWindows": "none", // Don't restore windows on startup
  "window.zoomLevel": 1, // Zoom level for entire interface
  "security.workspace.trust.untrustedFiles": "open", // Open untrusted files without prompt
  "task.notifyWindowOnTaskCompletion": 0, // Silent task completion notifications
  "taskexplorer.enablePersistentFileCaching": false, // Disable task explorer file caching

  // 🔍 Diff Editor
  "diffEditor.ignoreTrimWhitespace": true, // Ignore trim whitespace in diffs
  "diffEditor.codeLens": true, // Show code lens in diff editor
  "diffEditor.hideUnchangedRegions.enabled": true, // Collapse unchanged regions in diff

  // 🐞 Debug & Problems
  "debug.javascript.usePreview": false, // Disable JavaScript debug preview
  "debug.onTaskErrors": "abort", // Abort on task errors
  "problems.showCurrentInStatus": true, // Show current problem in status bar

  // ═══════════════════════════════════════════════════════════════════════════
  // 📁  5. FILE MANAGEMENT & ASSOCIATIONS
  // ═══════════════════════════════════════════════════════════════════════════

  // 💾 File Encoding & Cleanup - Text encoding and automatic cleanup
  "files.encoding": "utf8", // Use UTF-8 encoding for all files
  "files.trimTrailingWhitespace": true, // Remove trailing spaces on save
  "files.defaultLanguage": "plaintext", // Default language for new files

  // 🏷️ File Type Associations - Custom file type mappings
  "files.associations": {
    "*.rmd": "markdown", // R Markdown files as Markdown
    "*.conf": "wdl", // Configuration files as WDL
    "*.md": "markdown", // Markdown files
    "*.css": "tailwindcss" // CSS files with Tailwind support
  },

  // 🚫 File Exclusions - Hide certain files/folders from explorer
  "files.exclude": {
    "**/__pycache__": true, // Python cache files
    "**/.git": true, // Git repository data
    "**/.svn": true, // SVN repository data
    "**/.hg": true, // Mercurial repository data
    "**/.Rproj.user": true, // R project user files
    "**/.ipynb_checkpoints": true, // Jupyter notebook checkpoints
    "**/node_modules": true, // Node.js dependencies
    "**/bower_components": true, // Bower dependencies
    "**/venv": true, // Python virtual environments
    "**/.venv": true, // Python virtual environments (alternate)
    "**/*.egg-info": true, // Python package info
    "**/dist": true, // Distribution/build directories
    "**/*.git": true
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // 🔍  6. SEARCH & INDEXING
  // ═══════════════════════════════════════════════════════════════════════════

  // 🔎 Search Behavior - Global search settings
  "search.followSymlinks": false, // Don't follow symbolic links when searching

  // 🚫 Search Exclusions - Directories and files to exclude from search
  "search.exclude": {
    "**/node_modules": true, // JavaScript dependencies
    "**/bower_components": true, // Bower dependencies
    "**/*.code-search": true, // VS Code search indices
    "**/venv": true, // Python virtual environments
    "**/.venv": true, // Python virtual environments (alternate)
    "**/templates": true, // Template directories
    "**/rda": true, // R data files
    "**/.Rproj.user": true, // R project user files
    "**/*.pytest_cache": true, // Python test cache
    "**/*.ipynb": true, // Jupyter notebooks
    "**/*.ipynb_checkpoints": true, // Jupyter checkpoints
    "**/*.Rmd_files": true, // R Markdown output files
    "**/*.Rproj": true, // R project files
    "**/*.rda": true, // R data files
    "**/*.rds": true, // R data files
    "**/*.rds.gz": true, // Compressed R data files
    "**/*.egg-info": true, // Python package info
    "**/dist": true, // Distribution directories,
    "**/.git/": true,
    "**/data/**": true,
    "**/large-scale/**": true,
    "**/zzz/": true,
    "**/*.excalidraw": true
  },
  "files.watcherExclude": {
    ".ruff_cache/": true,
    ".venv/": true,
    "**/data/**": true,
    "**/large-scale/**": true,
    "**/zzz/": true,
    "**/.git/": true,
    "**/.git/objects/**": true
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // 💻  7. TERMINAL
  // ═══════════════════════════════════════════════════════════════════════════

  // 🎨 Terminal Appearance
  "terminal.external.osxExec": "Ghostty.app", // Use iTerm as external terminal on macOS
  "terminal.external.windowsExec": "wt", // Use Windows Terminal on Windows
  "terminal.integrated.copyOnSelection": true, // Line cursor style
  "terminal.integrated.fontSize": 14, // Font size for terminal
  "terminal.integrated.fontFamily": "'Cascadia Code', 'Fira Code', 'Symbols Nerd Font Mono', monospace",
  "terminal.integrated.fontLigatures": true, // Enable font ligatures in terminal
  "terminal.integrated.rendererType": "dom", // Use DOM renderer for better performance
  "terminal.integrated.rightClickBehavior": "copyPaste", // Keep headers visible when scrolling
  "terminal.integrated.shellIntegration.enabled": true, // Enable shell integration features
  "terminal.integrated.shellIntegration.decorationsEnabled setting": true, // Enable shell integration decorations
  "terminal.integrated.suggest.enabled": false, // Enable terminal command suggestions
  "terminal.integrated.inheritEnv": true, // Inherit environment variables
  "terminal.integrated.enableVisualBell": true, // Flash terminal on bell
  "terminal.integrated.enableMultiLinePasteWarning": "never", // Don't warn about multi-line paste
  "terminal.integrated.cursorBlinking": true, // Cursor blinking in terminal
  "terminal.integrated.cursorStyle": "line", // Line-style cursor
  "terminal.integrated.fontLigatures.enabled": true, // Font ligatures in terminal
  "terminal.integrated.smoothScrolling": true, // Smooth scrolling
  "terminal.integrated.initialHint": false, // Hide initial hint
  "terminal.integrated.stickyScroll.enabled": false, // Disable sticky scroll
  "terminal.integrated.allowInUntrustedWorkspace": true, // Allow in untrusted workspaces

  // 🐚 Default Shell Profiles
  "terminal.integrated.defaultProfile.osx": "bash", // Use zsh on macOS
  "terminal.integrated.defaultProfile.windows": "Git Bash", // Use Git Bash on Windows
  "terminal.integrated.defaultProfile.linux": "bash", // Use bash on Linux

  // 🔧 Terminal Profile Configurations - Custom shell profiles
  "terminal.integrated.profiles.osx": {
    "bash": {
      "path": "bash",
      "args": ["-l"],
      "icon": "terminal-bash"
    },
    "zsh": {
      "path": "/bin/zsh",
      "args": ["-i"]
    },
    "fish": {
      "path": "fish",
      "args": ["-l"]
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    }
  },
  "terminal.integrated.profiles.windows": {
    "Git Bash": {
      "path": "C:\\Users\\liuc9\\AppData\\Local\\Programs\\Git\\bin\\bash.exe",
      "args": ["-i"]
    }
  },
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "bash",
      "icon": "terminal-bash",
      "args": [
        // "--init-file",
        // "/home/liuc9/tools/miniforge3/etc/profile.d/conda.sh"
        "-i"
      ],
      "group": "activated",
      "overrideName": true
    },
    "zsh": {
      "path": "zsh"
    },
    "fish": {
      "path": "fish"
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    }
  },
  "chat.tools.terminal.terminalProfile.linux": {
    "path": "bash",
    "args": ["-i"],
    "env": {
      "COPILOT": "1"
    }
  },
  "chat.tools.terminal.terminalProfile.osx": {
    "path": "bash",
    "args": ["-i"],
    "env": {
      "COPILOT": "1"
    }
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // 📚  8. VERSION CONTROL — GIT & SCM
  // ═══════════════════════════════════════════════════════════════════════════

  // 🌳 Git Core
  "git.ignoreLegacyWarning": true, // Hide legacy Git warnings
  "git.autofetch": true, // Automatically fetch changes
  "git.confirmSync": false, // Don't confirm sync operations
  "git.enableSmartCommit": true, // Smart commit behavior
  "git.mergeEditor": true, // Use built-in merge editor
  "git.verboseCommit": true, // Verbose commit messages
  "git.openRepositoryInParentFolders": "never", // Don't open repos in parent folders

  // 🔍 GitLens
  "gitlens.mode.active": "zen", // Use zen mode for GitLens

  // 📋 SCM Panel
  "scm.showIncomingChanges": "always", // Always show incoming changes
  "scm.showOutgoingChanges": "always", // Always show outgoing changes
  "scm.alwaysShowRepositories": true, // Always show repository list
  "scm.repositories.explorer": true, // Show repositories in explorer
  "githubPullRequests.codingAgent.uiIntegration": true, // GitHub Copilot PR agent UI

  // ═══════════════════════════════════════════════════════════════════════════
  // 🐍  9. PYTHON DEVELOPMENT
  // ═══════════════════════════════════════════════════════════════════════════

  // 🔧 Interpreter & Environment
  "python.useEnvironmentsExtension": true, // Use Python environments extension
  "python.condaPath": "conda", // Path to conda executable
  "python.terminal.activateEnvironment": true, // Activate environment in terminal
  "python.terminal.activateEnvInCurrentTerminal": true, // Activate in current terminal
  "python.terminal.shellIntegration.enabled": true, // Enable terminal shell integration
  "python.terminal.useEnvFile": true, // Use .env file for terminal environment

  // 🧠 Language Server & Analysis
  "python.languageServer": "None", // Use Pylance instead of built-in server
  "python.analysis.disabled": ["unresolved-import"], // Disable unresolved import warnings
  "python.analysis.autoImportCompletions": true, // Auto-complete imports
  "python.analysis.completeFunctionParens": true, // Add parentheses to function completions
  "python.analysis.typeCheckingMode": "standard", // Standard type checking
  "python.analysis.memory.keepLibraryAst": true, // Keep library AST in memory
  "python.analysis.diagnosticMode": "openFilesOnly", // Only analyze open files
  "python.analysis.inlayHints.functionReturnTypes": true, // Show return type hints
  "python.analysis.supportAllPythonDocuments": true, // Support all Python documents
  "python.analysis.exclude": [
    // Exclude from analysis
    "**/__pycache__",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/node_modules",
    "**/cromwell-executions/**"
  ],

  // 🧪 Python Testing Configuration - Test framework settings
  "python.testing.pytestEnabled": true, // Enable pytest
  "python.testing.pytestArgs": ["tests"], // Run tests from tests directory
  "python.testing.unittestEnabled": false, // Disable unittest
  "python.testing.autoTestDiscoverOnSaveEnabled": false, // Don't auto-discover tests on save

  // ✨ Python Code Completion & Formatting - Editor enhancements
  "python.autoComplete.addBrackets": true, // Add brackets to completions
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "python-envs.defaultEnvManager": "ms-python.python:conda", // Default env manager
  "python-envs.defaultPackageManager": "ms-python.python:conda", // Default package manager
  "python-envs.terminal.showActivateButton": true, // Show env activate button in terminal

  // 🐍 Python File-Specific Settings
  "[python]": {
    "editor.formatOnSave": true, // Format Python files on save
    "editor.formatOnType": true, // Format as you type
    "editor.insertSpaces": true, // Use spaces instead of tabs
    "editor.tabSize": 4, // Use 4 spaces for Python (PEP 8)
    "editor.formatOnSaveMode": "file", // Format entire file on save
    "editor.codeActionsOnSave": {
      // Auto-fix and organize imports on save
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff", // Use Ruff as default formatter
    "diffEditor.ignoreTrimWhitespace": false // Consider whitespace in diffs
  },

  // 🦀 Ruff Linter Configuration - Fast Python linter and formatter
  "ruff.nativeServer": "on", // Use native Ruff server
  "ruff.lineLength": 80, // Line length limit
  "ruff.lint.ignore": ["F401"], // Ignore unused import warnings

  // 📝 Python Documentation - Auto-docstring settings
  "autoDocstring.startOnNewLine": true, // Start docstrings on new line

  // ═══════════════════════════════════════════════════════════════════════════
  // 📓 10. JUPYTER & DATA SCIENCE
  // ═══════════════════════════════════════════════════════════════════════════

  // 🚀 Jupyter Server & Execution
  "jupyter.askForKernelRestart": false, // Don't ask before restarting kernel
  "jupyter.exportWithOutputEnabled": true, // Include output when exporting
  "jupyter.jupyterInterruptTimeout": 1000000, // Long timeout for interrupting kernels
  "jupyter.jupyterServerType": "local", // Use local Jupyter server
  "jupyter.interactiveWindow.creationMode": "perFile", // Create interactive window per file
  "jupyter.interactiveWindow.textEditor.executeSelection": true, // Execute selected text

  // 📱 Notebook Appearance & Behavior - Visual and interaction settings
  "notebook.diff.enablePreview": false, // Disable notebook diff preview
  "notebook.lineNumbers": "on", // Show line numbers in cells
  "notebook.outline.showCodeCells": true, // Show code cells in outline
  "notebook.showFoldingControls": "always", // Always show folding controls
  "notebook.formatOnSave.enabled": true, // Format notebooks on save
  "notebook.formatOnCellExecution": false, // Don't format on cell execution
  "notebook.output.scrolling": true, // Enable output scrolling
  "notebook.output.textLineLimit": 30, // Limit output text lines

  // 🔧 Notebook Toolbar Configuration - Toolbar layout and visibility
  "notebook.cellToolbarLocation": {
    "default": "right", // Default toolbar location
    "jupyter-notebook": "right" // Jupyter notebook toolbar location
  },
  "notebook.cellToolbarVisibility": "hover", // Show toolbar on hover

  // ⚡ Notebook Code Actions - Automatic code improvements
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll": "explicit", // Fix all issues on save
    "notebook.source.organizeImports": "explicit" // Organize imports on save
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // 🌐 11. WEB DEVELOPMENT & LANGUAGES
  // ═══════════════════════════════════════════════════════════════════════════

  // 📘 TypeScript

  // 🏷️ HTML Configuration - HTML language settings
  "html.autoClosingTags": true, // Auto-close HTML tags

  // 🎨 Language-Specific Formatting - Per-language formatter settings
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "always"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "always"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "always"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "always"
    },
    "editor.foldingStrategy": "auto",
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "docker.docker"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "shellformat.effectLanguages": [
    "shellscript",
    "dockerfile",
    "ignore",
    "properties",
    "hosts",
    "bats"
  ],

  // 💅 Prettier — JavaScript / TypeScript Formatter
  "prettier.jsxSingleQuote": true, // Use single quotes in JSX
  "prettier.singleQuote": true, // Use single quotes
  "prettier.requirePragma": true, // Require pragma comment
  "prettier.printWidth": 80, // Line width limit
  "prettier.useTabs": false, // Use spaces instead of tabs
  "prettier.tabWidth": 2, // 2 spaces for indentation
  "prettier.bracketSpacing": true, // Spaces in object literals
  "prettier.trailingComma": "es5", // Trailing commas where valid
  "prettier.enable": true, // Enable Prettier
  "prettier.semi": true, // Use semicolons
  "prettier.arrowParens": "always", // Always wrap arrow function params

  // 🔍 ESLint Configuration - JavaScript/TypeScript linting
  "eslint.format.enable": true, // Enable ESLint formatting
  "eslint.run": "onSave", // Run ESLint on save
  "eslint.validate": [
    // File types to validate
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // ⚡ Emmet Configuration - HTML/CSS expansion shortcuts
  "emmet.triggerExpansionOnTab": true, // Expand Emmet on Tab
  "emmet.showSuggestionsAsSnippets": false, // Don't show as snippets
  "emmet.includeLanguages": {
    // Enable Emmet in additional languages
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "razor": "html",
    "plaintext": "pug"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // 📊 12. R PROGRAMMING
  // ═══════════════════════════════════════════════════════════════════════════

  // 🔧 R Language Server (LSP)
  "r.lsp.enabled": true,
  "r.lsp.diagnostics": true, // Disable R LSP diagnostics
  "r.lsp.debug": true, // Enable R LSP debugging
  "r.lsp.promptToInstall": false, // Don't prompt to install packages
  "r.lsp.use_stdio": true,
