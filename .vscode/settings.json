{
  "python-envs.defaultEnvManager": "renan-r-santos.pixi-code:pixi",
  "python-envs.defaultPackageManager": "renan-r-santos.pixi-code:pixi",
  // Let Pixi activate env automatically
  "python.terminal.activateEnvironment": true,

  // R executable (pixi environment)
  "r.rpath.mac": "${workspaceFolder}/.pixi/envs/default/bin/R",
  "r.rterm.mac": "/opt/homebrew/bin/arf",
  "terminal.integrated.env.osx": {
    "R_HOME": "${workspaceFolder}/.pixi/envs/default/lib/R"
  },

  // Linux only if needed
  "r.rpath.linux": "${workspaceFolder}/.pixi/envs/default/bin/R",
  "r.rterm.linux": "/home/cliu68/.cargo/bin/arf",
  "terminal.integrated.env.linux": {
    "R_HOME": "${workspaceFolder}/.pixi/envs/default/lib/R"
  },

  "r.rterm.option": ["--no-save", "--no-restore"],
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.pixi": true
  }
}
