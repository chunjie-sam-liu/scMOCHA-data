{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "watcher": {
    "ignore": [
      "high-res-MANUSCRIPTFIGURES-notuse/**",
      "high-res-MANUSCRIPTFIGURES/**",
      "analysis/zzz/**",
      "large-scale/**",
      "data/**",
      ".git/**"
    ]
  },
  "permission": {
    "git *": "allow",
    "npm *": "allow"
  },
  "instructions": [".opencode/guidelines.md"],
  "formatter": {
    "ruff": {
      "command": ["ruff", "check", "--fix", "."],
      "extensions": [".py"]
    },
    "air": {
      "command": ["air", "."],
      "extensions": [".R"]
    }
  }
}
