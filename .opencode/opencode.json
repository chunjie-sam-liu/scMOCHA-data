{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.2-codex",
  "watcher": {
    "ignore": [
      "high-res-MANUSCRIPTFIGURES-notuse/**",
      "high-res-MANUSCRIPTFIGURES/**",
      "analysis/zzz/**",
      "large-scale/**",
      "data/**",
      ".git/**"
    ]
  },
  "permission": {
    "git *": "allow",
    "npm *": "allow"
  },
  "tui": {
    "scroll_acceleration": {
      "enabled": true
    },
    "scroll_speed": 3
  },
  "instructions": [".opencode/guidelines.md"],
  "keybinds": {
    "input_submit": "cmd+return",
    "input_newline": "return,shift+return,ctrl+return,alt+return,ctrl+j"
  },
  "formatter": {
    "ruff": {
      "command": ["ruff", "check", "--fix", "."],
      "extensions": [".py"]
    },
    "air": {
      "command": ["air", "."],
      "extensions": [".R"]
    }
  }
}
